# OPA-CMS Environment Configuration
# Kopiere diese Datei nach .env und passe die Werte an.
# Bei Nutzung des install-ubuntu.sh Skripts wird .env automatisch erstellt.

# ============================================================
# SERVER
# ============================================================
PORT=5000

# JWT-Secret für Admin-Sessions – wird automatisch generiert.
# NICHT manuell ändern, wenn Benutzer eingeloggt sind.
ADMIN_SECRET=change-this-to-a-long-random-string

# Lizenzserver-URL (Standard: Produktiv-Server, nur für Entwicklung ändern)
LICENSE_SERVER_URL=https://licens-prod.stb-srv.de

# Auf true setzen für Entwicklungsmodus (lockert einige Prüfungen)
DEV_MODE=false

# ============================================================
# CORS – Erlaubte Domains
# ============================================================
# Alle Domains die auf diesen Server zugreifen, kommagetrennt.
# Muss die Domain(s) enthalten, unter denen das CMS / die Website erreichbar ist.
# Beispiel für eine Domain mit und ohne www:
# CORS_ORIGINS=https://meinrestaurant.de,https://www.meinrestaurant.de
#
# Für lokale Entwicklung:
# CORS_ORIGINS=http://localhost:3000,http://localhost:5000
CORS_ORIGINS=https://meinrestaurant.de

# ============================================================
# SMTP – E-Mail-Konfiguration (für Reservierungsbestätigungen)
# ============================================================
# Kann alternativ komplett über das CMS unter Einstellungen > E-Mail
# eingerichtet werden – dann sind diese Werte hier nicht nötig.
#
# Gängige Provider:
#   IONOS / 1&1:  smtp.ionos.de         Port 465  SMTP_SECURE=true
#   Strato:       smtp.strato.de        Port 465  SMTP_SECURE=true
#   GMX:          mail.gmx.net          Port 465  SMTP_SECURE=true
#   Gmail:        smtp.gmail.com        Port 587  SMTP_SECURE=false
#   Office 365:   smtp.office365.com    Port 587  SMTP_SECURE=false

SMTP_HOST=smtp.ionos.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@meinrestaurant.de
SMTP_PASS=dein-smtp-passwort
SMTP_FROM="OPA! Santorini" <info@meinrestaurant.de>
