# OPA-CMS Environment Configuration
# Copy this file to .env and fill in your values

PORT=5000
ADMIN_SECRET=change-this-to-a-long-random-string
LICENSE_SERVER_URL=http://localhost:4000
DEV_MODE=false

# SMTP Settings
SMTP_HOST=smtp.dein-provider.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ihre-email@restaurant.de
SMTP_PASS=ihr-geheimes-passwort
SMTP_FROM="OPA! Santorini" <noreply@restaurant.de>

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://deine-domain.de
