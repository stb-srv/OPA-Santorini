# OPA-CMS Environment Configuration
# Copy this file to .env and fill in your values

PORT=5000
ADMIN_SECRET=change-this-to-a-long-random-string
LICENSE_SERVER_URL=https://licens-prod.stb-srv.de
DEV_MODE=false

# SMTP Settings
SMTP_HOST=smtp.dein-provider.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ihre-email@restaurant.de
SMTP_PASS=ihr-geheimes-passwort
SMTP_FROM="OPA! Santorini" <noreply@restaurant.de>

# CORS Allowed Origins (comma-separated, include ALL domains that access this server)
# Example: https://meinrestaurant.de,https://www.meinrestaurant.de
CORS_ORIGINS=https://meinrestaurant.de
